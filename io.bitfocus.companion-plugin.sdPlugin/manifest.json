{
	"$schema": "../node_modules/@elgato/schemas/streamdeck/plugins/manifest.json",
	"Name": "Bitfocus Companion Plugin",
	"Version": "3.3.1.0",
	"Author": "Bitfocus AS",
	"Actions": [
		{
			"Name": "Companion Button",
			"UUID": "io.bitfocus.companion-plugin.action",
			"Icon": "img/actionIcon",
			"Tooltip": "Control anything in companion",
			"Controllers": ["Keypad", "Encoder"],
			"Encoder": {
				"layout": "encoderLayout.json"
			},
			"SupportedInMultiActions": true,
			"States": [
				{
					"Image": "img/loadingIcon"
				}
			]
		}
	],
	"Category": "Bitfocus Companion Plugin",
	"CategoryIcon": "img/pluginIcon",
	"CodePath": "bin/plugin.js",
	"PropertyInspectorPath": "propertyinspector.html",
	"Description": "Connect a Stream Deck to Companion, while still allowing other Elgato marketplace plugins to be used.",
	"Icon": "img/pluginIcon",
	"URL": "https://bitfocus.io/companion/",
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "7.1"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "11"
		},
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		}
	],
	"Nodejs": {
		"Version": "24"
	},
	"UUID": "io.bitfocus.companion-plugin",
	"Profiles": [
		{
			"Name": "profiles/companion",
			"DeviceType": 0
		},
		{
			"Name": "profiles/companionMini",
			"DeviceType": 1
		},
		{
			"Name": "profiles/companionXL",
			"DeviceType": 2
		},
		{
			"Name": "profiles/companionPlus",
			"DeviceType": 7
		},
		{
			"Name": "profiles/companionNeo",
			"DeviceType": 9
		}
	]
}
