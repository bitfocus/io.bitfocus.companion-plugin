{
	"scripts": {
		"build": "rollup -c",
		"watch": "rollup -c --nocache -w --watch.onEnd=\"streamdeck restart io.bitfocus.companion-plugin\"",
		"link": "streamdeck link io.bitfocus.companion-plugin.sdPlugin",
		"pack": "streamdeck pack io.bitfocus.companion-plugin.sdPlugin",
		"restart": "streamdeck restart io.bitfocus.companion-plugin",
		"format": "prettier -w .",
		"check-types": "tsc --noEmit",
		"vendor": "node scripts/download-vendor.mjs"
	},
	"type": "module",
	"devDependencies": {
		"@elgato/cli": "^1.7.4",
		"@rollup/plugin-commonjs": "^29.0.3",
		"@rollup/plugin-image": "^3.0.3",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@tsconfig/node20": "^20.1.9",
		"@types/node": "^24.13.3",
		"@types/pngjs": "^6.0.5",
		"@types/semver": "^7.7.1",
		"@types/ws": "^8.18.1",
		"prettier": "^3.9.5",
		"rollup": "^4.62.2",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.1.0",
		"pngjs": "^7.0.0",
		"semver": "^7.8.5",
		"ws": "^8.21.0"
	},
	"packageManager": "yarn@4.14.0"
}
